void create_product(int productid)
{
organizationID = "";
get_product = invokeurl
[
	url :"https://aaaaaa-bq.myshopify.com/admin/api/2026-04/products/" + productid + ".json"
	type :GET
	connection:"shopify_con"
];
// info get_product;
product = get_product.get("product");
item_map = Map();
variants = product.getJSON("variants");
if(variants.size() > 1)
{
	attribute_name1 = product.getJSON("options").getJSON("name");
	item_map.put("can_be_purchased",true);
	item_map.put("can_be_sold",true);
	item_map.put("track_inventory",true);
	itemstatus = product.getJSON("status");
	item_map.put("item_type","inventory");
	item_map.put("product_type","goods");
	item_map.put("status","active");
	item_map.put("group_name",ifnull(product.getJSON("title"),""));
	item_map.put("unit",ifnull(variants.getJSON("weight_unit"),""));
	item_map.put("attribute_name1",attribute_name1);
	description = ifnull(product.getJSON("body_html"),"");
	if(description != "")
	{
		description = description.replaceAll("<(.|\n)*?>","").replaceAll("&nbsp;"," ");
		item_map.put("description",description);
	}
	var_list = List();
	ids_list = List();
	for each  var in variants
	{
		var_map = Map();
		var_map.put("can_be_purchased",true);
		var_map.put("can_be_sold",true);
		var_map.put("track_inventory",true);
		var_map.put("item_type","inventory");
		var_map.put("product_type","goods");
		var_map.put("status","active");
		var_map.put("name",ifnull(var.getJSON("title"),""));
		var_map.put("unit",ifnull(var.getJSON("weight_unit"),""));
		var_map.put("rate",ifnull(var.getJSON("price"),"0"));
		var_map.put("purchase_rate",ifnull(var.getJSON("price"),"0"));
		var_map.put("attribute_option_name1",ifnull(var.getJSON("option1"),"0"));
