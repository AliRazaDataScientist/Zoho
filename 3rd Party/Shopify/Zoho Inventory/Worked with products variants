		custom_field_update_map1.put("customfield_id","8924607000000358050");
		custom_field_update_map1.put("label","Variant ID");
		custom_field_update_map1.put("value",var.getJSON("id").toLong());
		custome_field_list = List();
		custome_field_list.add(custom_field_update_map);
		custome_field_list.add(custom_field_update_map1);
		ids = Map();
		ids.put("names",var.getJSON("title"));
		ids.put("ids",custome_field_list);
		ids_list.add(ids);
		qty = var.getJSON("inventory_quantity");
		if(qty <= 0)
		{
			qty = 0;
		}
		available = ifnull(qty,0);
		price = ifnull(var.getJSON("price"),0);
		inventory_map = Map();
		inventory_map.put("location_id","8924607000000093121");
		inventory_map.put("initial_stock",available);
		inventory_map.put("initial_stock_rate",available.tonumber() * price.toNumber());
		var_map.put("locations",{inventory_map});
		var_list.add(var_map);
	}
	item_map.put("items",var_list);
	item_created = zoho.inventory.createRecord("itemgroups",organizationID,item_map,"inventory_con");
	item_group = item_created.getJSON("item_group");
	if(item_group.size() > 0)
	{
		items = item_group.getJSON("items");
		for each  item in items
		{
			name = item.getJSON("name");
			for each  idlist in ids_list
			{
				idsname = idlist.getJSON("names");
				ids = idlist.getJSON("ids");
				if(idsname == name)
				{
					itemid = item.getJSON("item_id");
					updateMAP = Map();
					updateMAP.put("custom_fields",ids);
					update_book = zoho.inventory.updateRecord("items",organizationID,itemid,updateMAP,"inventory_con");
					info "update_book" + update_book;
				}
			}
		}
	}
	info item_created;
}
else
{
	item_map = Map();
	variants = product.getJSON("variants");
	item_map.put("can_be_purchased",true);
	item_map.put("can_be_sold",true);
	item_map.put("track_inventory",true);
	item_map.put("item_type","inventory");
	item_map.put("product_type","goods");
	item_map.put("status","active");
	item_map.put("name",ifnull(product.getJSON("title"),""));
	description = ifnull(product.getJSON("body_html"),"");
	if(description != "")
	{
		description = description.replaceAll("<(.|\n)*?>","").replaceAll("&nbsp;"," ");
		item_map.put("description",description);
	}
	item_map.put("rate",ifnull(variants.getJSON("price"),""));
	item_map.put("purchase_rate",ifnull(variants.getJSON("price"),""));
	item_map.put("unit",ifnull(variants.getJSON("weight_unit"),""));
	////////////Custom Field
	custom_field_update_map = Map();
	custom_field_update_map.put("customfield_id","8924607000000348059");
	custom_field_update_map.put("label","Shopify Product ID");
	custom_field_update_map.put("value",variants.getJSON("product_id").toLong());
	custom_field_update_map1 = Map();
	custom_field_update_map1.put("customfield_id","8924607000000358050");
	custom_field_update_map1.put("label","Variant ID");
	custom_field_update_map1.put("value",variants.getJSON("id").toLong());
	custome_field_list = List();
	custome_field_list.add(custom_field_update_map);
	custome_field_list.add(custom_field_update_map1);
	item_map.put("custom_fields",custome_field_list);
	qty = variants.getJSON("inventory_quantity");
	if(qty <= 0)
	{
		qty = 0;
	}
	available = ifnull(qty,0);
	price = ifnull(variants.getJSON("price"),0);
	inventory_map = Map();
	inventory_map.put("location_id","8924607000000093121");
	inventory_map.put("initial_stock",available);
	inventory_map.put("initial_stock_rate",available.tonumber() * price.toNumber());
	item_map.put("locations",{inventory_map});
	item_created = zoho.inventory.createRecord("items",organizationID,item_map,"inventory_con");
	itemid = item_created.getJSON("item").getJSON("item_id");
	info itemid;
}
}









